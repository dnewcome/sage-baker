# Copy to `.env` and fill in. The Makefile auto-loads .env and exports
# these variables to all sub-shells (so trainers and prepare scripts pick
# them up without needing to source the file manually).

# --- BigQuery / GCP ----------------------------------------------------
# Path to your GCP service-account JSON key. Used by prepare_bigquery.py.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- MLflow ------------------------------------------------------------
# Set to a tracking server URI to enable run/metric/artifact logging.
# Leave empty (or unset) to disable. The trainers no-op when unset.
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# --- AWS ---------------------------------------------------------------
# Only needed for DLC paths (local_train_dlc.py, local_train_feast_dlc.py).
# Prefer `aws sso login` over hardcoded keys.
# AWS_PROFILE=your-profile
# AWS_DEFAULT_REGION=us-east-1
